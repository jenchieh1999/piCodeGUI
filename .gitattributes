# Keep source-controlled text files stable across Windows/macOS/Linux.
* text=auto eol=lf

# Windows launchers are the only files that should keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets must not be normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.icns binary
*.bmp binary
*.pdf binary
*.zip binary
*.gz binary
*.7z binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
